{
  "manifest_version": 3,
  "name": "Prompt Improvement Assistant",
  "version": "1.0.0",
  "description": "Real-time AI prompt improvement suggestions as you type",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.js-iRaxGO8I.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Prompt Assistant"
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "options_page": "settings.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "styles.css",
        "assets/content.js-iRaxGO8I.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
